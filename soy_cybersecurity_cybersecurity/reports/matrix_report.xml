<odoo>

    <record id="matrix_individual_xlsx" model="ir.actions.report">
        <field name="name">Reporte de Matriz de Activos de la información</field>
        <field name="model">cyber_matrix.matrix</field>
        <field name="report_name">cyber_matrix_assets.report</field>
        <field name="report_type">xlsx</field>
        <field name="report_file">Matriz</field>
        <field name="print_report_name">'%s' % object.name"</field>
        <field name="groups_id" eval="[(6,0,[
            ref('base.group_no_one'),
            ref('soy_cybersecurity_cybersecurity.group_cybersecurity_onlyread'),
            ref('soy_cybersecurity_cybersecurity.group_cybersecurity_onlyread_printreport'),
            ref('soy_cybersecurity_cybersecurity.group_cybersecurity_user_secundario'),
            ref('soy_cybersecurity_cybersecurity.group_cybersecurity_write_printreport'),
        ])]"></field>
        <field name="binding_model_id" ref="model_cyber_matrix_matrix"></field>

    </record>
</odoo>